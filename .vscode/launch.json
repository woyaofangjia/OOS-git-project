{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Debug on Tomcat",
            "request": "launch",
            "mainClass": "org.apache.catalina.startup.Bootstrap",
            "args": ["start"],
            "classPaths": [
                "${workspaceFolder}/target/classes",
                "${workspaceFolder}/tomcat/apache-tomcat-8.5.88/lib/*"
            ],
            "vmArgs": [
                "-Dcatalina.home=${workspaceFolder}/tomcat/apache-tomcat-8.5.88",
                "-Dcatalina.base=${workspaceFolder}/tomcat/apache-tomcat-8.5.88",
                "-Djava.io.tmpdir=${workspaceFolder}/tomcat/apache-tomcat-8.5.88/temp",
                "-Dfile.encoding=UTF-8",
                "-Xdebug",
                "-Xrunjdwp:transport=dt_socket,server=y,suspend=n,address=8000"
            ],
            "projectName": "Campus-Second-Hand"
        },
        {
            "type": "java",
            "name": "Attach to Tomcat",
            "request": "attach",
            "hostName": "localhost",
            "port": 8000
        },
        {
            "type": "java",
            "name": "Debug Maven Build",
            "request": "launch",
            "mainClass": "org.codehaus.plexus.classworlds.launcher.Launcher",
            "args": [
                "tomcat7:run"
            ],
            "classPaths": [
                "${workspaceFolder}/target/classes"
            ],
            "vmArgs": [
                "-Dfile.encoding=UTF-8",
                "-Xdebug",
                "-Xrunjdwp:transport=dt_socket,server=y,suspend=y,address=8000"
            ],
            "projectName": "Campus-Second-Hand"
        }
    ]
}